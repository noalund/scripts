#!/bin/bash
set -euo pipefail

if ! curl -sf http://localhost:11434/api/tags >/dev/null; then
    mkdir -p ~/.cache

    ollama serve > ~/.cache/ollama_server.log 2>&1 &

    for i in {1..20}; do
        if curl -sf http://localhost:11434/api/tags >/dev/null; then
            break
        fi
        sleep 0.5
    done

    curl -sf http://localhost:11434/api/tags >/dev/null || {
        echo "Ollama failed" >&2
        exit 1
    }
fi

exec kitty -e ollama run kimi-k2.6:cloud
