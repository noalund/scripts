#!/bin/bash

# Create local snapshots of home directory

set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: $(basename "$0") [drive]"
    echo
    echo "Mounted drives:"
    ls "/run/media/$USER"
    exit 1
fi

BASE="/run/media/${USER}/$1"
SOURCE="$HOME"

if ! mountpoint -q "$BASE"; then
    echo "Drive not mounted or does not exist:"
    echo "  $BASE"
    exit 1
fi

DAY=$(date +%d)

if [ "$DAY" = "01" ]; then
    TYPE="monthly"
    LIMIT=12
else
    TYPE="daily"
    LIMIT=30
fi

DEST="$BASE/$TYPE"
TIMESTAMP=$(date +"%Y-%m-%d_%H-%M-%S")
TARGET="$DEST/$TIMESTAMP"
LATEST="$DEST/latest"

mkdir -p "$TARGET"

# If a previous backup exists, use it for linking:
if [ -d "$LATEST" ]; then
    LINKDEST="--link-dest=$LATEST"
else
    LINKDEST=""
fi

rsync -avAX --numeric-ids --delete \
    ${LINKDEST:+$LINKDEST} \
    --exclude='.cache' \
    --exclude='.local/share/Trash' \
    --exclude='downloads' \
    "$SOURCE/" "$TARGET/"

# Update latest symlink
ln -sfn "$TARGET" "$LATEST"

# Count snapshots (ignore the 'latest' symlink)
COUNT=$(find "$DEST" -mindepth 1 -maxdepth 1 -type d | wc -l)

if [ "$COUNT" -gt "$LIMIT" ]; then
    notify-send "Backup Warning" \
    "$TYPE backups exceed limit ($COUNT > $LIMIT)"
fi
